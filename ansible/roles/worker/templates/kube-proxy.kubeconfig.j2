apiVersion: v1
kind: Config
clusters:
- cluster:
    certificate-authority: {{ k8s_cert_dir }}/ca.crt
    server: https://{{ haproxy_ip }}:{{ apiserver_port }}
  name: kubernetes
contexts:
- context:
    cluster: kubernetes
    user: system:kube-proxy
  name: default
current-context: default
users:
- name: system:kube-proxy
  user:
    client-certificate: {{ k8s_cert_dir }}/kube-proxy.crt
    client-key: {{ k8s_cert_dir }}/kube-proxy.key
