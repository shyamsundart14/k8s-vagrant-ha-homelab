[Unit]
Description=Kubernetes API Server
Documentation=https://kubernetes.io/docs/reference/command-line-tools-reference/kube-apiserver/
After=network.target

[Service]
ExecStart=/usr/local/bin/kube-apiserver \
  --advertise-address={{ node_ip }} \
  --allow-privileged=true \
  --apiserver-count={{ apiserver_count }} \
  --audit-log-maxage=30 \
  --audit-log-maxbackup=3 \
  --audit-log-maxsize=100 \
  --audit-log-path=/var/log/kubernetes/audit.log \
  --authorization-mode=Node,RBAC \
  --bind-address=0.0.0.0 \
  --client-ca-file={{ k8s_cert_dir }}/ca.crt \
  --enable-admission-plugins=NodeRestriction \
  --enable-bootstrap-token-auth=true \
  --encryption-provider-config={{ k8s_config_dir }}/encryption-config.yaml \
  --etcd-cafile={{ k8s_cert_dir }}/etcd/ca.crt \
  --etcd-certfile={{ k8s_cert_dir }}/apiserver-etcd-client.crt \
  --etcd-keyfile={{ k8s_cert_dir }}/apiserver-etcd-client.key \
  --etcd-servers={{ etcd_endpoints }} \
  --event-ttl=1h \
  --kubelet-certificate-authority={{ k8s_cert_dir }}/ca.crt \
  --kubelet-client-certificate={{ k8s_cert_dir }}/apiserver-kubelet-client.crt \
  --kubelet-client-key={{ k8s_cert_dir }}/apiserver-kubelet-client.key \
  --proxy-client-cert-file={{ k8s_cert_dir }}/front-proxy-client.crt \
  --proxy-client-key-file={{ k8s_cert_dir }}/front-proxy-client.key \
  --requestheader-allowed-names=front-proxy-client \
  --requestheader-client-ca-file={{ k8s_cert_dir }}/front-proxy-ca.crt \
  --requestheader-extra-headers-prefix=X-Remote-Extra- \
  --requestheader-group-headers=X-Remote-Group \
  --requestheader-username-headers=X-Remote-User \
  --secure-port={{ apiserver_port }} \
  --service-account-issuer=https://kubernetes.default.svc.cluster.local \
  --service-account-key-file={{ k8s_cert_dir }}/sa.pub \
  --service-account-signing-key-file={{ k8s_cert_dir }}/sa.key \
  --service-cluster-ip-range={{ service_cidr }} \
  --tls-cert-file={{ k8s_cert_dir }}/apiserver.crt \
  --tls-private-key-file={{ k8s_cert_dir }}/apiserver.key \
  --v=2

Restart=on-failure
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
