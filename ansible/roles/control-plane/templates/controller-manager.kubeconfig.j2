apiVersion: v1
kind: Config
clusters:
- cluster:
    certificate-authority: {{ k8s_cert_dir }}/ca.crt
    server: https://127.0.0.1:{{ apiserver_port }}
  name: kubernetes
contexts:
- context:
    cluster: kubernetes
    user: system:kube-controller-manager
  name: default
current-context: default
users:
- name: system:kube-controller-manager
  user:
    client-certificate: {{ k8s_cert_dir }}/controller-manager.crt
    client-key: {{ k8s_cert_dir }}/controller-manager.key
